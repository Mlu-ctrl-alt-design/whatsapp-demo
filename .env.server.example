# Copy to .env.server (gitignored via *.local — rename to .env.server.local
# if you'd rather keep this naming, or just `source` it before `npm run server`).
#
# Used by server/index.js — these are the server-side equivalents of the
# VITE_CRM_* vars used by the client.

PORT=3001
DATA_DIR=./data

CRM_BASE_URL=https://crm.thedaystar.co.za
CRM_API_KEY=
CRM_API_SECRET=
CRM_CAMPAIGN=SAFPA
CRM_LEAD_DOCTYPE=CRM Lead

# Comma-separated list of allowed origins for CORS; * for any.
# e.g. https://booth.thedaystar.co.za,http://localhost:5173
CORS_ORIGIN=*
